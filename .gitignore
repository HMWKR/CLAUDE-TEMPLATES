# macOS
.DS_Store
.AppleDouble
.LSOverride

# Editor
.vscode/
.idea/
*.swp
*.swo
*~

# Logs / temp
*.log
*.tmp

# 런타임 캐시 — 로컬 경로·UUID 포함, git 추적 안 함
cache/

# 작업 데이터 — 사용자 사적 자료, git 추적 안 함 (폴더 구조 유지를 위해 .gitkeep만 추적)
tasks/*
!tasks/.gitkeep

# 프로젝트 특화 교훈 — 작성자 사적 누적물, git 추적 안 함 (폴더만 유지)
_local/*
!_local/.gitkeep

# 의존성 — git 추적 안 함
node_modules/

# 로컬 도구 상태/캐시 — 머신 특화, git 추적 안 함
.serena/
.omc/
.bkit/
.agents/
.playwright-mcp/
.obsidian/
.claude/anti-loop-state.json
.claude/anti-loop-state.json.bak

# 개인 산출물 (스크린샷·PDF·저널·스크래치) — git 추적 안 함
/*.png
/*.pdf
.thoughts/
Excalidraw/
*.canvas
*.base
checkpoint.md
.task-state.md
